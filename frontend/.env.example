# ─── Desenvolvimento local ─────────────────────────────────────────
NEXT_PUBLIC_API_URL=http://localhost:3001/api

# Origem do backend Nest (rewrite /liga7-api → …/api). Local padrão: http://localhost:3001
# BACKEND_ORIGIN=http://localhost:3001

# ─── Vercel (produção) — rewrite em frontend/vercel.json: /api/proxy → API Railway ─
# Se mudar o host da API, atualize "rewrites" em vercel.json (a edge não lê BACKEND_ORIGIN).
# Não use NEXT_PUBLIC_API_URL apontando direto para a Railway.
#
# Site: https://liga7esports-frontend.vercel.app
#
# Monorepo: Root Directory do projeto Vercel = "frontend".
