# ─── Desenvolvimento local ─────────────────────────────────────────
NEXT_PUBLIC_API_URL=http://localhost:3001/api

# Origem do backend Nest (rewrite /liga7-api → …/api). Local padrão: http://localhost:3001
# BACKEND_ORIGIN=http://localhost:3001

# ─── Vercel (produção) — proxy em app/api/proxy (evita CORS na edge Railway) ─
# Obrigatório no Vercel (Runtime): origem do Nest, sem /api no final.
# BACKEND_ORIGIN=https://liga7esports-api.railway.app
# Não use NEXT_PUBLIC_API_URL apontando direto para a Railway.
#
# Site: https://liga7esports-frontend.vercel.app
#
# Monorepo: no projeto Vercel, Root Directory = "frontend" (senão o /api/proxy não entra no deploy).
