# ─── Desenvolvimento local ─────────────────────────────────────────
NEXT_PUBLIC_API_URL=http://localhost:3001/api

# Origem do backend Nest (rewrite /liga7-api → …/api). Local padrão: http://localhost:3001
# BACKEND_ORIGIN=http://localhost:3001

# ─── Vercel (produção) — recomendado (evita CORS na edge Railway) ─
# NÃO defina NEXT_PUBLIC_API_URL apontando para a Railway; o frontend usa /liga7-api.
# Defina só:
# BACKEND_ORIGIN=https://liga7esports-api.railway.app
#
# Site: https://liga7esports-frontend.vercel.app
